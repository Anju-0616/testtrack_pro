generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  email            String            @unique
  password         String
  id               Int               @id @default(autoincrement())
  role Role @default(TESTER)
  isVerified        Boolean @default(false)
  verificationToken String?
  verificationTokenExpiry DateTime?
  resetToken       String?
  resetTokenExpiry DateTime?
  refreshToken     String?
  passwordHistory  PasswordHistory[]
  passwordResets   PasswordReset[]
  refreshTokens    RefreshToken[]

  reportedBugs Bug[] @relation("ReportedBugs")
  assignedBugs Bug[] @relation("AssignedBugs")

  bugComment BugComment[]

  executions TestExecution[]
}

enum Role {
  TESTER
  DEVELOPER
  }
model TestCase {
  title       String
  description String?
  priority    Priority @default(MEDIUM)
  status      Status   @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   Int
  id          Int      @id @default(autoincrement())
  isDeleted   Boolean  @default(false)

  executions TestExecution[]
  bugs       Bug[]
  steps TestCaseStep[]

  module String
}

model PasswordHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  password  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  used      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TestExecution {
  id           Int      @id @default(autoincrement())

  testcaseId   Int
  testcase     TestCase @relation(fields: [testcaseId], references: [id], onDelete: Cascade)

  executedBy   Int
  tester       User     @relation(fields: [executedBy], references: [id])

  status       String
  executedAt   DateTime @default(now())

  startedAt    DateTime?
  completedAt  DateTime?
  duration     Int?

  executionSteps ExecutionStep[]
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Status {
  DRAFT
  READY
  ARCHIVED
}

model Bug {
  id               Int        @id @default(autoincrement())
  bugId            String     @unique

  title            String
  description      String
  stepsToReproduce String
  expectedBehavior String
  actualBehavior   String

  severity         Severity
  priority         BugPriority
  status           BugStatus  @default(NEW)

  environment      String?
  affectedVersion  String?

  // Developer Resolution Fields
  fixNotes         String?
  commitHash       String?
  branchName       String?
  resolvedAt       DateTime?

  // Relations
  assignedToId     Int?
  assignedTo       User?      @relation("AssignedBugs", fields: [assignedToId], references: [id])

  testCaseId       Int?
  testCase         TestCase?  @relation(fields: [testCaseId], references: [id])

  createdById      Int
  createdBy        User       @relation("ReportedBugs", fields: [createdById], references: [id])

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  Comment BugComment[]
}

enum Severity {
  BLOCKER
  CRITICAL
  MAJOR
  MINOR
  TRIVIAL
}

enum BugPriority {
  P1_URGENT
  P2_HIGH
  P3_MEDIUM
  P4_LOW
}

enum BugStatus {
  NEW
  OPEN
  IN_PROGRESS
  FIXED
  VERIFIED
  CLOSED
  REOPENED
  WONT_FIX
  DUPLICATE
}

model BugComment {
  id        Int      @id @default(autoincrement())
  content   String

  bugId     Int
  bug       Bug      @relation(fields: [bugId], references: [id], onDelete: Cascade)

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExecutionStep {
  id              Int      @id @default(autoincrement())

  executionId     Int
  execution       TestExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  testCaseStepId  Int
  testCaseStep    TestCaseStep  @relation(fields: [testCaseStepId], references: [id])

  actualResult    String?
  stepStatus      ExecutionStepStatus?
}

enum ExecutionStepStatus {
  PASS
  FAIL
  BLOCKED
  SKIPPED
}

model TestCaseStep {
  id            Int      @id @default(autoincrement())

  testCaseId    Int
  testCase      TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  stepNumber    Int
  action        String
  expectedResult String

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  executionSteps ExecutionStep[]
}
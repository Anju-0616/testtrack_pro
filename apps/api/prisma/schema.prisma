generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  email                   String            @unique
  password                String
  name                    String?
  id                      Int               @id @default(autoincrement())
  role                    Role              @default(TESTER)
  isVerified              Boolean           @default(false)
  verificationToken       String?
  verificationTokenExpiry DateTime?
  resetToken              String?
  resetTokenExpiry        DateTime?
  refreshToken            String?
  assignedBugs            Bug[]             @relation("AssignedBugs")
  reportedBugs            Bug[]             @relation("ReportedBugs")
  bugComment              BugComment[]
  passwordHistory         PasswordHistory[]
  passwordResets          PasswordReset[]
  refreshTokens           RefreshToken[]
  executions              TestExecution[]
  dashboardLayout         String?
  notifications           Notification[]
  assignedTestCases       TestCase[]        @relation("AssignedTestCases")
}

model TestCase {
  title        String
  description  String?
  priority     Priority        @default(MEDIUM)
  status       Status          @default(DRAFT)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  createdBy    Int
  id           Int             @id @default(autoincrement())
  isDeleted    Boolean         @default(false)
  module       String
  assignedToId Int?
  assignedTo   User?           @relation("AssignedTestCases", fields: [assignedToId], references: [id])
  bugs         Bug[]
  steps        TestCaseStep[]
  executions   TestExecution[]
}

model PasswordHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  password  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  used      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TestExecution {
  id             Int             @id @default(autoincrement())
  testcaseId     Int
  executedBy     Int
  status         String
  executedAt     DateTime        @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  duration       Int?
  executionSteps ExecutionStep[]
  tester         User            @relation(fields: [executedBy], references: [id])
  testcase       TestCase        @relation(fields: [testcaseId], references: [id], onDelete: Cascade)
}

model Bug {
  id               Int          @id @default(autoincrement())
  bugId            String       @unique
  title            String
  description      String
  stepsToReproduce String
  expectedBehavior String
  actualBehavior   String
  severity         Severity
  priority         BugPriority
  status           BugStatus    @default(NEW)
  environment      String?
  affectedVersion  String?
  fixNotes         String?
  commitHash       String?
  branchName       String?
  resolvedAt       DateTime?
  assignedToId     Int?
  testCaseId       Int?
  createdById      Int
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  assignedTo       User?        @relation("AssignedBugs", fields: [assignedToId], references: [id])
  createdBy        User         @relation("ReportedBugs", fields: [createdById], references: [id])
  testCase         TestCase?    @relation(fields: [testCaseId], references: [id])
  Comment          BugComment[]
}

model BugComment {
  id        Int      @id @default(autoincrement())
  content   String
  bugId     Int
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bug       Bug      @relation(fields: [bugId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExecutionStep {
  id             Int                  @id @default(autoincrement())
  executionId    Int
  testCaseStepId Int
  actualResult   String?
  stepStatus     ExecutionStepStatus?
  execution      TestExecution        @relation(fields: [executionId], references: [id], onDelete: Cascade)
  testCaseStep   TestCaseStep         @relation(fields: [testCaseStepId], references: [id])
}

model TestCaseStep {
  id             Int             @id @default(autoincrement())
  testCaseId     Int
  stepNumber     Int
  action         String
  expectedResult String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  executionSteps ExecutionStep[]
  testCase       TestCase        @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
}

enum Role {
  TESTER
  DEVELOPER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Status {
  DRAFT
  READY
  ARCHIVED
}

enum Severity {
  BLOCKER
  CRITICAL
  MAJOR
  MINOR
  TRIVIAL
}

enum BugPriority {
  P1_URGENT
  P2_HIGH
  P3_MEDIUM
  P4_LOW
}

enum BugStatus {
  NEW
  OPEN
  IN_PROGRESS
  FIXED
  VERIFIED
  CLOSED
  REOPENED
  WONT_FIX
  DUPLICATE
}

enum ExecutionStepStatus {
  PASS
  FAIL
  BLOCKED
  SKIPPED
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String
  title       String
  message     String
  relatedId   String?
  relatedType String? // BUG, TEST_CASE, COMMENT
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

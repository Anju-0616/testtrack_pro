generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  email            String            @unique
  password         String
  id               Int               @id @default(autoincrement())
  role Role @default(TESTER)
  isVerified        Boolean @default(false)
  verificationToken String?
  verificationTokenExpiry DateTime?
  resetToken       String?
  resetTokenExpiry DateTime?
  refreshToken     String?
  passwordHistory  PasswordHistory[]
  passwordResets   PasswordReset[]
  refreshTokens    RefreshToken[]

  reportedBugs Bug[] @relation("ReportedBugs")
  assignedBugs Bug[] @relation("AssignedBugs")
}

enum Role {
  TESTER
  DEVELOPER
  }
model TestCase {
  title       String
  description String?
  priority    Priority @default(MEDIUM)
  status      Status   @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   Int
  id          Int      @id @default(autoincrement())
  isDeleted   Boolean  @default(false)

  executions TestExecution[]
  bugs       Bug[]
}

model PasswordHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  password  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  used      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TestExecution {
  id         Int      @id @default(autoincrement())
  testcaseId Int
  executedBy Int
  status     String
  executedAt DateTime @default(now())
  testcase   TestCase @relation(fields: [testcaseId], references: [id], onDelete: Cascade)
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Status {
  DRAFT
  READY
  ARCHIVED
}

model Bug {
  id               Int    @id @default(autoincrement())
  bugId            String @unique
  title            String
  description      String
  stepsToReproduce String
  expectedBehavior String
  actualBehavior   String

  severity Severity
  priority BugPriority
  status   BugStatus   @default(NEW)

  environment     String?
  affectedVersion String?

  assignedToId Int?
  assignedTo   User? @relation("AssignedBugs", fields: [assignedToId], references: [id])

  testCaseId Int?
  testCase   TestCase? @relation(fields: [testCaseId], references: [id])

  createdById Int
  createdBy   User @relation("ReportedBugs", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Severity {
  BLOCKER
  CRITICAL
  MAJOR
  MINOR
  TRIVIAL
}

enum BugPriority {
  P1_URGENT
  P2_HIGH
  P3_MEDIUM
  P4_LOW
}

enum BugStatus {
  NEW
  OPEN
  IN_PROGRESS
  FIXED
  VERIFIED
  CLOSED
  REOPENED
  WONT_FIX
  DUPLICATE
}
